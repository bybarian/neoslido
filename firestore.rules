rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions for Path Variable and String Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Validation Helper for Question
    function isValidQuestion(data) {
      return data.title is string && data.title.size() <= 300
        && data.createdAt is timestamp
        && data.isActive is bool
        && data.categories is list
        && data.categories.size() <= 15
        && (data.categories.size() == 0 || (data.categories.size() > 0 && data.categories[0] is string))
        && (!("type" in data) || data.type is string)
        && (!("options" in data) || data.options is list)
        && (!("imageUrl" in data) || data.imageUrl == null || data.imageUrl is string)
        && (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    // Validation Helper for Answer
    function isValidAnswer(data) {
      return data.text is string && data.text.size() <= 1000
        && data.category is string && data.category.size() <= 100
        && data.createdAt is timestamp
        && data.userId is string && data.userId.size() <= 128
        && (!("userName" in data) || (data.userName is string && data.userName.size() <= 100))
        && (!("userTitle" in data) || (data.userTitle is string && data.userTitle.size() <= 100))
        && (!("userHospital" in data) || (data.userHospital is string && data.userHospital.size() <= 100));
    }

    match /questions/{questionId} {
      allow get, list: if true;
      allow create: if isValidId(questionId) && isValidQuestion(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidId(questionId) && isValidQuestion(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isValidId(questionId);
      
      match /answers/{answerId} {
        allow get, list: if true;
        allow create: if isValidId(answerId) && isValidAnswer(incoming()) && incoming().createdAt == request.time;
        allow update: if isValidId(answerId) && isValidAnswer(incoming());
        allow delete: if isValidId(answerId);
      }
    }

    match /settings/{settingId} {
      allow get, list: if true;
      allow create, update: if isValidId(settingId);
      allow delete: if isValidId(settingId);
    }
  }
}
